# AI Database Architect — example configuration.
# Copy this file to web/.env.local (for the web app) and fill in real values.
# NEVER commit your real .env.local — it is gitignored.

# ---------------------------------------------------------------------------
# LLM (prompt -> backend). Default 'stub' runs fully offline (no AWS needed).
# ---------------------------------------------------------------------------
AIDA_LLM_PROVIDER=stub            # stub | bedrock | http

# When AIDA_LLM_PROVIDER=bedrock:
# AIDA_LLM_PROVIDER=bedrock
# AIDA_BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
# AIDA_BEDROCK_REGION=us-east-1
# AWS credentials come from your standard AWS chain (aws configure / env / IAM role).

# When AIDA_LLM_PROVIDER=http (OpenAI-compatible endpoint):
# AIDA_LLM_ENDPOINT=https://api.example.com/v1/chat/completions
# AIDA_LLM_API_KEY=sk-...
# AIDA_LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Deployment target. Default 'memory' is in-process (no database needed).
# Set 'postgres' to deploy generated schemas to a live RDS/Aurora PostgreSQL.
# ---------------------------------------------------------------------------
AIDA_DEPLOY_TARGET=memory         # memory | postgres

# When AIDA_DEPLOY_TARGET=postgres:
# AIDA_DEPLOY_TARGET=postgres
# AIDA_DB_HOST=your-instance.xxxxxxxx.us-east-1.rds.amazonaws.com
# AIDA_DB_PORT=5432
# AIDA_DB_NAME=yourdb
# AIDA_DB_USER=youruser
# AIDA_DB_PASSWORD=your-password
