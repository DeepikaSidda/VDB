node_modules/
# The compiled engine `dist/src` is committed so the Vercel web build can
# bundle it without running a cross-folder TypeScript build. Everything else
# under dist/ (e.g. dist/test) stays ignored.
/dist/*
!/dist/src
*.tsbuildinfo

# Secrets / local config — never commit
.aida-db-pw.txt
.env
.env.*
!.env.example

# Vercel CLI local link (project IDs; not needed in repo)
.vercel
